# Copy to .env.local and fill in to connect a Supabase backend.
# Without these, the app runs on the local-storage store (seeded demo data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (no NEXT_PUBLIC_ prefix). Needed for coach-initiated athlete
# password resets. From Supabase → Settings → API → service_role / sb_secret_.
SUPABASE_SERVICE_ROLE_KEY=
