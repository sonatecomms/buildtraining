# Copy to .env.local and fill in to connect a Supabase backend.
# Without these, the app runs on the local-storage store (seeded demo data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (no NEXT_PUBLIC_ prefix). Needed for coach-initiated athlete
# password resets. From Supabase → Settings → API → service_role / sb_secret_.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Transactional email (Resend) for athlete password-recovery links.
# Without these, phone/username recovery emails silently won't send.
RESEND_API_KEY=
BUILD_FROM_EMAIL=BUILD <noreply@yourdomain.com>

# Canonical site URL — used to build recovery links server-side (never trusts the
# request Origin). Defaults to https://buildtraining.vercel.app.
NEXT_PUBLIC_SITE_URL=

# Server-only. Anthropic API key for the "Build me a workout" generator. From
# console.anthropic.com → API keys. Without it, the generator returns an error.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8).
ANTHROPIC_MODEL=
